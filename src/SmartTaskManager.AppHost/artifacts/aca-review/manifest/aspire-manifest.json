{
  "$schema": "https://json.schemastore.org/aspire-8.0.json",
  "resources": {
    "aca-env": {
      "type": "azure.bicep.v0",
      "path": "aca-env.module.bicep",
      "params": {
        "userPrincipalId": ""
      }
    },
    "smarttaskmanager-api": {
      "type": "project.v1",
      "path": "../../../../SmartTaskManager.Api/SmartTaskManager.Api.csproj",
      "deployment": {
        "type": "azure.bicep.v0",
        "path": "smarttaskmanager-api-containerapp.module.bicep",
        "params": {
          "aca_env_outputs_azure_container_apps_environment_default_domain": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_DEFAULT_DOMAIN}",
          "aca_env_outputs_azure_container_apps_environment_id": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_ID}",
          "aca_env_outputs_azure_container_registry_endpoint": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_ENDPOINT}",
          "aca_env_outputs_azure_container_registry_managed_identity_id": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_MANAGED_IDENTITY_ID}",
          "smarttaskmanager_api_containerimage": "{smarttaskmanager-api.containerImage}",
          "smarttaskmanager_api_containerport": "{smarttaskmanager-api.containerPort}",
          "smarttaskmanagersqlconnectionstring_value": "{smartTaskManagerSqlConnectionString.value}"
        }
      },
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{smarttaskmanager-api.bindings.http.targetPort}",
        "ConnectionStrings__SmartTaskManager": "{smartTaskManagerSqlConnectionString.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "smarttaskmanager-web": {
      "type": "project.v1",
      "path": "../../../../SmartTaskManager.Web/SmartTaskManager.Web.csproj",
      "deployment": {
        "type": "azure.bicep.v0",
        "path": "smarttaskmanager-web-containerapp.module.bicep",
        "params": {
          "aca_env_outputs_azure_container_apps_environment_default_domain": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_DEFAULT_DOMAIN}",
          "aca_env_outputs_azure_container_apps_environment_id": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_ID}",
          "aca_env_outputs_azure_container_registry_endpoint": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_ENDPOINT}",
          "aca_env_outputs_azure_container_registry_managed_identity_id": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_MANAGED_IDENTITY_ID}",
          "smarttaskmanager_web_containerimage": "{smarttaskmanager-web.containerImage}",
          "smarttaskmanager_web_containerport": "{smarttaskmanager-web.containerPort}",
          "webazureadclientsecret_value": "{webAzureAdClientSecret.value}"
        }
      },
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{smarttaskmanager-web.bindings.http.targetPort}",
        "SMARTTASKMANAGER-API_HTTP": "{smarttaskmanager-api.bindings.http.url}",
        "services__smarttaskmanager-api__http__0": "{smarttaskmanager-api.bindings.http.url}",
        "SMARTTASKMANAGER-API_HTTPS": "{smarttaskmanager-api.bindings.https.url}",
        "services__smarttaskmanager-api__https__0": "{smarttaskmanager-api.bindings.https.url}",
        "SmartTaskManagerApi__BaseUrl": "{smarttaskmanager-api.bindings.https.url}",
        "AzureAd__ClientSecret": "{webAzureAdClientSecret.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        }
      }
    },
    "smartTaskManagerSqlConnectionString": {
      "type": "parameter.v0",
      "value": "{smartTaskManagerSqlConnectionString.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "webAzureAdClientSecret": {
      "type": "parameter.v0",
      "value": "{webAzureAdClientSecret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    }
  }
}