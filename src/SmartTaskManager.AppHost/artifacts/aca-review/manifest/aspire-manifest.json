{
  "$schema": "https://json.schemastore.org/aspire-8.0.json",
  "resources": {
    "aca-env": {
      "type": "azure.bicep.v0",
      "path": "aca-env.module.bicep",
      "params": {
        "userPrincipalId": ""
      }
    },
    "smarttaskmanager-api": {
      "type": "project.v1",
      "path": "../../../../SmartTaskManager.Api/SmartTaskManager.Api.csproj",
      "deployment": {
        "type": "azure.bicep.v0",
        "path": "smarttaskmanager-api-containerapp.module.bicep",
        "params": {
          "aca_env_outputs_azure_container_apps_environment_default_domain": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_DEFAULT_DOMAIN}",
          "aca_env_outputs_azure_container_apps_environment_id": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_ID}",
          "aca_env_outputs_azure_container_registry_endpoint": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_ENDPOINT}",
          "aca_env_outputs_azure_container_registry_managed_identity_id": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_MANAGED_IDENTITY_ID}",
          "smarttaskmanager_api_containerimage": "{smarttaskmanager-api.containerImage}",
          "smarttaskmanager_api_containerport": "{smarttaskmanager-api.containerPort}",
          "smarttaskmanagersqlconnectionstring_value": "{smartTaskManagerSqlConnectionString.value}",
          "apiazureadinstance_value": "{apiAzureAdInstance.value}",
          "apiazureadtenantid_value": "{apiAzureAdTenantId.value}",
          "apiazureadclientid_value": "{apiAzureAdClientId.value}",
          "apiazureadaudience_value": "{apiAzureAdAudience.value}",
          "apiauthorizationrequiredscope_value": "{apiAuthorizationRequiredScope.value}"
        }
      },
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{smarttaskmanager-api.bindings.http.targetPort}",
        "ConnectionStrings__SmartTaskManager": "{smartTaskManagerSqlConnectionString.value}",
        "AzureAd__Instance": "{apiAzureAdInstance.value}",
        "AzureAd__TenantId": "{apiAzureAdTenantId.value}",
        "AzureAd__ClientId": "{apiAzureAdClientId.value}",
        "AzureAd__Audience": "{apiAzureAdAudience.value}",
        "Authorization__RequiredScope": "{apiAuthorizationRequiredScope.value}",
        "Database__EnableEfLogging": "false",
        "Database__EnableDetailedErrors": "false",
        "Database__EnableSensitiveDataLogging": "false",
        "Seeding__EnableSampleData": "false"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "smarttaskmanager-web": {
      "type": "project.v1",
      "path": "../../../../SmartTaskManager.Web/SmartTaskManager.Web.csproj",
      "deployment": {
        "type": "azure.bicep.v0",
        "path": "smarttaskmanager-web-containerapp.module.bicep",
        "params": {
          "aca_env_outputs_azure_container_apps_environment_default_domain": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_DEFAULT_DOMAIN}",
          "aca_env_outputs_azure_container_apps_environment_id": "{aca-env.outputs.AZURE_CONTAINER_APPS_ENVIRONMENT_ID}",
          "aca_env_outputs_azure_container_registry_endpoint": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_ENDPOINT}",
          "aca_env_outputs_azure_container_registry_managed_identity_id": "{aca-env.outputs.AZURE_CONTAINER_REGISTRY_MANAGED_IDENTITY_ID}",
          "smarttaskmanager_web_containerimage": "{smarttaskmanager-web.containerImage}",
          "smarttaskmanager_web_containerport": "{smarttaskmanager-web.containerPort}",
          "webazureadclientsecret_value": "{webAzureAdClientSecret.value}",
          "webazureadinstance_value": "{webAzureAdInstance.value}",
          "webazureadtenantid_value": "{webAzureAdTenantId.value}",
          "webazureadclientid_value": "{webAzureAdClientId.value}",
          "webazureadcallbackpath_value": "{webAzureAdCallbackPath.value}",
          "webazureadsignedoutcallbackpath_value": "{webAzureAdSignedOutCallbackPath.value}",
          "smarttaskmanagerapiaudience_value": "{smartTaskManagerApiAudience.value}",
          "smarttaskmanagerapiscopes_value": "{smartTaskManagerApiScopes.value}"
        }
      },
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{smarttaskmanager-web.bindings.http.targetPort}",
        "SMARTTASKMANAGER-API_HTTP": "{smarttaskmanager-api.bindings.http.url}",
        "services__smarttaskmanager-api__http__0": "{smarttaskmanager-api.bindings.http.url}",
        "SMARTTASKMANAGER-API_HTTPS": "{smarttaskmanager-api.bindings.https.url}",
        "services__smarttaskmanager-api__https__0": "{smarttaskmanager-api.bindings.https.url}",
        "SmartTaskManagerApi__BaseUrl": "{smarttaskmanager-api.bindings.https.url}",
        "AzureAd__Instance": "{webAzureAdInstance.value}",
        "AzureAd__TenantId": "{webAzureAdTenantId.value}",
        "AzureAd__ClientId": "{webAzureAdClientId.value}",
        "AzureAd__ClientSecret": "{webAzureAdClientSecret.value}",
        "AzureAd__CallbackPath": "{webAzureAdCallbackPath.value}",
        "AzureAd__SignedOutCallbackPath": "{webAzureAdSignedOutCallbackPath.value}",
        "SmartTaskManagerApi__Audience": "{smartTaskManagerApiAudience.value}",
        "SmartTaskManagerApi__Scopes": "{smartTaskManagerApiScopes.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        }
      }
    },
    "smartTaskManagerSqlConnectionString": {
      "type": "parameter.v0",
      "value": "{smartTaskManagerSqlConnectionString.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "webAzureAdClientSecret": {
      "type": "parameter.v0",
      "value": "{webAzureAdClientSecret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "webAzureAdInstance": {
      "type": "parameter.v0",
      "value": "{webAzureAdInstance.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "webAzureAdTenantId": {
      "type": "parameter.v0",
      "value": "{webAzureAdTenantId.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "webAzureAdClientId": {
      "type": "parameter.v0",
      "value": "{webAzureAdClientId.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "webAzureAdCallbackPath": {
      "type": "parameter.v0",
      "value": "{webAzureAdCallbackPath.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "webAzureAdSignedOutCallbackPath": {
      "type": "parameter.v0",
      "value": "{webAzureAdSignedOutCallbackPath.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "smartTaskManagerApiAudience": {
      "type": "parameter.v0",
      "value": "{smartTaskManagerApiAudience.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "smartTaskManagerApiScopes": {
      "type": "parameter.v0",
      "value": "{smartTaskManagerApiScopes.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "apiAzureAdInstance": {
      "type": "parameter.v0",
      "value": "{apiAzureAdInstance.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "apiAzureAdTenantId": {
      "type": "parameter.v0",
      "value": "{apiAzureAdTenantId.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "apiAzureAdClientId": {
      "type": "parameter.v0",
      "value": "{apiAzureAdClientId.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "apiAzureAdAudience": {
      "type": "parameter.v0",
      "value": "{apiAzureAdAudience.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    },
    "apiAuthorizationRequiredScope": {
      "type": "parameter.v0",
      "value": "{apiAuthorizationRequiredScope.inputs.value}",
      "inputs": {
        "value": {
          "type": "string"
        }
      }
    }
  }
}
