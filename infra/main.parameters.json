{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      },
      "apiAuthorizationRequiredScope": {
        "value": "${AZURE_API_AUTHORIZATION_REQUIRED_SCOPE}"
      },
      "apiAzureAdAudience": {
        "value": "${AZURE_API_AZURE_AD_AUDIENCE}"
      },
      "apiAzureAdClientId": {
        "value": "${AZURE_API_AZURE_AD_CLIENT_ID}"
      },
      "apiAzureAdInstance": {
        "value": "${AZURE_API_AZURE_AD_INSTANCE}"
      },
      "apiAzureAdTenantId": {
        "value": "${AZURE_API_AZURE_AD_TENANT_ID}"
      },
      "smartTaskManagerApiAudience": {
        "value": "${AZURE_SMART_TASK_MANAGER_API_AUDIENCE}"
      },
      "smartTaskManagerApiScopes": {
        "value": "${AZURE_SMART_TASK_MANAGER_API_SCOPES}"
      },
      "smartTaskManagerSqlConnectionString": {
        "value": "${AZURE_SMART_TASK_MANAGER_SQL_CONNECTION_STRING}"
      },
      "webAzureAdCallbackPath": {
        "value": "${AZURE_WEB_AZURE_AD_CALLBACK_PATH}"
      },
      "webAzureAdClientId": {
        "value": "${AZURE_WEB_AZURE_AD_CLIENT_ID}"
      },
      "webAzureAdClientSecret": {
        "value": "${AZURE_WEB_AZURE_AD_CLIENT_SECRET}"
      },
      "webAzureAdInstance": {
        "value": "${AZURE_WEB_AZURE_AD_INSTANCE}"
      },
      "webAzureAdSignedOutCallbackPath": {
        "value": "${AZURE_WEB_AZURE_AD_SIGNED_OUT_CALLBACK_PATH}"
      },
      "webAzureAdTenantId": {
        "value": "${AZURE_WEB_AZURE_AD_TENANT_ID}"
      },
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      }
    }
  }
  